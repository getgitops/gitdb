{
  "name": "@kettu/gitdb",
  "version": "0.1.0",
  "description": "Database abstraction helpers for GitVault modules",
  "license": "MIT",
  "author": "kettu",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "files": [
    "dist"
  ],
  "sideEffects": false,
  "repository": {
    "type": "git",
    "url": "https://github.com/kettu/gitvault-suite.git",
    "directory": "packages/gitdb"
  },
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "clean": "rm -rf dist",
    "build": "tsup src/index.ts --dts --format esm,cjs --clean",
    "dev": "tsup src/index.ts --dts --format esm,cjs --watch",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "demo": "npm run build && node --experimental-strip-types test-git-db.ts",
    "changeset": "changeset",
    "version-packages": "changeset version",
    "release": "npm run clean && npm run build && npm run typecheck && npm run test && changeset publish",
    "prepublishOnly": "npm run clean && npm run build && npm run typecheck && npm run test"
  },
  "engines": {
    "node": ">=20"
  },
  "devDependencies": {
    "@changesets/cli": "^2.29.6",
    "@types/node": "^22.10.1",
    "tsup": "^8.3.5",
    "typescript": "^5.6.3",
    "vitest": "^2.1.8"
  }
}
